{
  "name": "shuvo-queue-studio",
  "displayName": "Shuvo Queue Studio",
  "description": "Queue-based command runner with local Ollama model selection for VS Code",
  "version": "0.0.10",
  "publisher": "shuvo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/engrmehedihasanshuvo/shuvo-queue-studio.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "os": ["darwin", "win32", "linux"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorQueueAssistant.open",
        "title": "Shuvo Queue Studio: Open"
      },
      {
        "command": "cursorQueueAssistant.chooseModel",
        "title": "Shuvo Queue Studio: Choose Local Model"
      },
      {
        "command": "cursorQueueAssistant.addTask",
        "title": "Shuvo Queue Studio: Add Task"
      },
      {
        "command": "cursorQueueAssistant.runQueue",
        "title": "Shuvo Queue Studio: Run Queue"
      },
      {
        "command": "cursorQueueAssistant.openPanel",
        "title": "Shuvo Queue Studio: Open Floating Panel"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "shuvoQueueStudioView",
          "name": "Shuvo Queue Studio",
          "type": "webview",
          "icon": "media/shuvo-queue-studio.svg",
          "visibility": "visible"
        }
      ]
    },
    "configuration": {
      "title": "Shuvo Queue Studio",
      "properties": {
        "cursorQueueAssistant.ollamaBaseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama API base URL"
        },
        "cursorQueueAssistant.model": {
          "type": "string",
          "default": "llama3.1:8b",
          "description": "Default local model to use"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.8.3"
  }
}
